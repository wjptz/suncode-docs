{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "exclude": [
    ".trellis/**",
    "AGENTS.md",
    "marketplace/skills/**",
    "marketplace/agents/**",
    "marketplace/commands/**",
    "marketplace/specs/**",
    "marketplace/README.md"
  ],
  "name": "Trellis Doc",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "languages": [
      {
        "language": "en",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/specs",
              "guides/tasks",
              "guides/commands",
              "guides/multi-agent",
              "guides/faq"
            ]
          },
          {
            "group": "Resource Marketplace",
            "pages": [
              {
                "group": "Skills",
                "expanded": false,
                "pages": ["skills-market/index", "skills-market/trellis-meta"]
              },
              {
                "group": "Spec Templates",
                "expanded": false,
                "pages": ["templates/specs-index", "templates/specs-electron"]
              }
            ]
          },
          {
            "group": "Community",
            "pages": [
              "showcase/index",
              "contribute/index",
              {
                "group": "Tech Blog",
                "expanded": false,
                "pages": [
                  "blog/index",
                  "blog/use-k8s-to-know-trellis",
                  "blog/ai-collaborative-dev-system"
                ]
              },
              {
                "group": "Changelog",
                "expanded": false,
                "pages": [
                  "changelog/v0.3.0-beta.8",
                  "changelog/v0.3.0-beta.7",
                  "changelog/v0.3.0-beta.0",
                  "changelog/v0.2.0",
                  "changelog/v0.1.9"
                ]
              }
            ]
          }
        ]
      },
      {
        "language": "zh",
        "groups": [
          {
            "group": "开始使用",
            "pages": ["zh/index", "zh/quickstart"]
          },
          {
            "group": "指南",
            "pages": [
              "zh/guides/specs",
              "zh/guides/tasks",
              "zh/guides/commands",
              "zh/guides/multi-agent",
              "zh/guides/faq"
            ]
          },
          {
            "group": "Resource Marketplace",
            "pages": [
              {
                "group": "Skills",
                "expanded": false,
                "pages": ["zh/skills-market/index", "zh/skills-market/trellis-meta"]
              },
              {
                "group": "Spec Templates",
                "expanded": false,
                "pages": ["zh/templates/specs-index", "zh/templates/specs-electron"]
              }
            ]
          },
          {
            "group": "社区",
            "pages": [
              "zh/showcase/index",
              "zh/contribute/index",
              {
                "group": "Tech Blog",
                "expanded": false,
                "pages": [
                  "zh/blog/index",
                  "zh/blog/use-k8s-to-know-trellis",
                  "zh/blog/ai-collaborative-dev-system"
                ]
              },
              {
                "group": "Changelog",
                "expanded": false,
                "pages": [
                  "zh/changelog/v0.3.0-beta.8",
                  "zh/changelog/v0.3.0-beta.7",
                  "zh/changelog/v0.3.0-beta.0",
                  "zh/changelog/v0.2.0",
                  "zh/changelog/v0.1.9"
                ]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/mindfold-ai/Trellis",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Changelog",
        "href": "/changelog/v0.3.0-beta.8"
      },
      {
        "label": "Tech Blog",
        "href": "/blog"
      }
    ],
    "primary": {
      "type": "button",
      "label": "GitHub",
      "href": "https://github.com/mindfold-ai/Trellis"
    }
  },
  "repository": {
    "url": "https://github.com/mindfold-ai/docs",
    "deployBranch": "main"
  },
  "contextual": {
    "options": ["chatgpt", "claude", "perplexity"]
  },
  "interaction": {
    "drilldown": true
  },
  "footer": {
    "socials": {
      "x": "https://x.com/_kleinhe",
      "github": "https://github.com/mindfold-ai/Trellis"
    }
  }
}
