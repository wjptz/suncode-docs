{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "js": "/terminal-demo.js",
  "exclude": [".suncode/**", "AGENTS.md"],
  "name": "Suncode Docs",
  "colors": {
    "primary": "#0F766E",
    "light": "#06B6D4",
    "dark": "#2563EB"
  },
  "appearance": {
    "default": "system"
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "grid"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "dark"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "languages": [
      {
        "language": "en",
        "versions": [
          {
            "version": "Release",
            "groups": [
              {
                "group": "Start Here",
                "pages": [
                  "index",
                  "start/install-and-first-task",
                  "start/how-it-works",
                  "start/everyday-use",
                  "start/team-hub",
                  "start/real-world-scenarios"
                ]
              },
              {
                "group": "Advanced",
                "pages": [
                  "advanced/architecture",
                  "advanced/roadmap",
                  "advanced/custom-workflow",
                  "advanced/custom-commands",
                  "advanced/custom-agents",
                  "advanced/custom-hooks",
                  "advanced/custom-skills",
                  "advanced/custom-spec-template-marketplace",
                  "advanced/configuration",
                  "advanced/multi-platform",
                  "advanced/appendix-a",
                  "advanced/appendix-b",
                  "advanced/appendix-c",
                  "advanced/appendix-d",
                  "advanced/appendix-f",
                  "advanced/resources"
                ]
              }
            ],
            "default": true
          }
        ]
      },
      {
        "language": "zh",
        "versions": [
          {
            "version": "Release",
            "groups": [
              {
                "group": "开始使用",
                "pages": [
                  "zh/index",
                  "zh/start/install-and-first-task",
                  "zh/start/how-it-works",
                  "zh/start/everyday-use",
                  "zh/start/team-hub",
                  "zh/start/real-world-scenarios"
                ]
              },
              {
                "group": "进阶",
                "pages": [
                  "zh/advanced/architecture",
                  "zh/advanced/roadmap",
                  "zh/advanced/custom-workflow",
                  "zh/advanced/custom-commands",
                  "zh/advanced/custom-agents",
                  "zh/advanced/custom-hooks",
                  "zh/advanced/custom-skills",
                  "zh/advanced/custom-spec-template-marketplace",
                  "zh/advanced/configuration",
                  "zh/advanced/multi-platform",
                  "zh/advanced/appendix-a",
                  "zh/advanced/appendix-b",
                  "zh/advanced/appendix-c",
                  "zh/advanced/appendix-d",
                  "zh/advanced/appendix-f",
                  "zh/advanced/resources"
                ]
              }
            ],
            "default": true
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/wjptz/suncode",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "GitHub",
      "href": "https://github.com/wjptz/suncode"
    }
  },
  "repository": {
    "url": "https://github.com/wjptz/suncode-docs",
    "deployBranch": "main"
  },
  "contextual": {
    "options": ["chatgpt", "claude", "perplexity"]
  },
  "interaction": {
    "drilldown": true
  },
  "footer": {
    "socials": {
      "github": "https://github.com/wjptz/suncode"
    }
  },
  "redirects": []
}
