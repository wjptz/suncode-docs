{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "exclude": [".trellis/**", "AGENTS.md"],
  "name": "Trellis",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "languages": [
      {
        "language": "en",
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Getting started",
                "pages": ["index", "quickstart"]
              },
              {
                "group": "Core concepts",
                "pages": ["concepts/overview"]
              },
              {
                "group": "How to use",
                "pages": [
                  "guides/specs",
                  "guides/tasks",
                  "guides/commands",
                  "guides/multi-agent",
                  "guides/faq"
                ]
              },
              {
                "group": "Templates",
                "pages": [
                  "templates/index",
                  "templates/specs",
                  "templates/commands",
                  "templates/skills",
                  "templates/customizing"
                ]
              },
              {
                "group": "Community",
                "pages": ["showcase/index", "contribute/index"]
              }
            ]
          }
        ]
      },
      {
        "language": "zh",
        "tabs": [
          {
            "tab": "指南",
            "groups": [
              {
                "group": "开始使用",
                "pages": ["zh/index", "zh/quickstart"]
              },
              {
                "group": "核心概念",
                "pages": ["zh/concepts/overview"]
              },
              {
                "group": "使用方法",
                "pages": [
                  "zh/guides/specs",
                  "zh/guides/tasks",
                  "zh/guides/commands",
                  "zh/guides/multi-agent",
                  "zh/guides/faq"
                ]
              },
              {
                "group": "模板",
                "pages": [
                  "zh/templates/index",
                  "zh/templates/specs",
                  "zh/templates/commands",
                  "zh/templates/skills",
                  "zh/templates/customizing"
                ]
              },
              {
                "group": "社区",
                "pages": ["zh/showcase/index", "zh/contribute/index"]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/mindfold-ai/Trellis",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:taosu@mindfold.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "GitHub",
      "href": "https://github.com/mindfold-ai/Trellis"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "mcp", "cursor", "vscode"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mindfold_ai",
      "github": "https://github.com/mindfold-ai/Trellis"
    }
  }
}
