{
  "name": "trellis-docs",
  "version": "1.0.0",
  "description": "Trellis Documentation Website - Built with Mintlify",
  "private": true,
  "scripts": {
    "dev": "mintlify dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . && markdownlint-cli2 '**/*.{md,mdx}' && node scripts/check-shared-groups.mjs",
    "lint:md": "markdownlint-cli2 '**/*.{md,mdx}'",
    "lint:js": "eslint .",
    "lint:docs-json": "node scripts/check-shared-groups.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{md,mdx}": [
      "markdownlint-cli2 --fix",
      "prettier --write"
    ],
    "*.{json,yaml,yml}": [
      "prettier --write"
    ],
    "docs.json": [
      "node scripts/check-shared-groups.mjs"
    ],
    "*.{js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "trellis",
    "documentation",
    "mintlify"
  ],
  "author": "Mindfold",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^20.4.0",
    "@commitlint/config-conventional": "^20.4.0",
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "markdownlint-cli2": "^0.20.0",
    "prettier": "^3.8.1"
  }
}
